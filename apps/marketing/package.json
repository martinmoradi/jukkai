{
  "name": "@jukkai/marketing",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "imports": {
    "#/*": "./src/*"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "bun ../../scripts/fonts-generated-check.ts && astro build",
    "dev": "bun ../../scripts/fonts-generated-check.ts && astro dev --host 0.0.0.0",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.astro && stylelint \"src/**/*.css\" --allow-empty-input",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs,.ts,.astro --fix && stylelint \"src/**/*.css\" --fix --allow-empty-input",
    "preview": "astro preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
