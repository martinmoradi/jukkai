---
import {
  GENERATED_FONTS_CSS_FILE,
  GENERATED_FONTS_PUBLIC_BASE_PATH,
} from '../../../../scripts/generated-font-assets';
import {
  buildSiteJsonLd,
  getAbsoluteSiteUrl,
  SITE_METADATA,
} from '../lib/site-metadata';

interface Props {
  canonicalPath?: string;
  description?: string;
  noindex?: boolean;
  title?: string;
}

const {
  canonicalPath = Astro.url.pathname,
  description = SITE_METADATA.defaultDescription,
  noindex = false,
  title = SITE_METADATA.defaultTitle,
} = Astro.props;

const canonicalUrl = getAbsoluteSiteUrl(canonicalPath);
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
const jsonLd = buildSiteJsonLd({
  canonicalPath,
  description,
  title,
});
const serializedJsonLd = JSON.stringify(jsonLd).replaceAll('<', '\\u003c');
const generatedFontsStylesheetHref = `${GENERATED_FONTS_PUBLIC_BASE_PATH}/${GENERATED_FONTS_CSS_FILE}`;
---

<meta charset='UTF-8' />
<meta name='viewport' content='width=device-width, initial-scale=1.0' />
<meta name='description' content={description} />
<meta name='robots' content={robots} />
<link rel='canonical' href={canonicalUrl} />
<link rel='stylesheet' href={generatedFontsStylesheetHref} />

<title>{title}</title>

<meta property='og:type' content='website' />
<meta property='og:locale' content={SITE_METADATA.locale} />
<meta property='og:site_name' content={SITE_METADATA.brandName} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:url' content={canonicalUrl} />

<meta name='twitter:card' content='summary' />
<meta name='twitter:title' content={title} />
<meta name='twitter:description' content={description} />

<script is:inline type='application/ld+json' set:html={serializedJsonLd} />
