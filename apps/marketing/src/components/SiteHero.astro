---
import styles from './SiteHero.module.css';

interface Props {
  eyebrow?: string;
  lead?: string;
  primaryCta?: {
    href: string;
    label: string;
  } | null;
  title?: string;
}

const {
  eyebrow = 'Jukkai by Crystelle Terrasson',
  lead = 'Architecture intérieure, art et lieu vivant à Châteaugiron. Le site complet arrive bientôt.',
  primaryCta,
  title = "Architecte d'intérieur à Rennes & Châteaugiron",
} = Astro.props;
---

<section class={styles.hero}>
  <div class={styles.copy}>
    <img
      class={styles.wordmark}
      src='/brand/jukkai-wordmark.svg'
      alt='Jukkai'
      width='2609'
      height='1021'
      decoding='async'
      fetchpriority='high'
    />
    <p class={styles.eyebrow}>{eyebrow}</p>
    <h1 class={styles.title}>{title}</h1>
    <p class={styles.lead}>{lead}</p>
    {
      primaryCta ? (
        <a class={styles.cta} href={primaryCta.href}>
          {primaryCta.label}
        </a>
      ) : null
    }
  </div>
  <div class={styles.panel} aria-hidden='true'>
    <span class={styles.panelLabel}>Jukkai</span>
    <span class={styles.panelRule}></span>
    <span class={styles.panelMeta}>Rennes + Châteaugiron</span>
  </div>
</section>
