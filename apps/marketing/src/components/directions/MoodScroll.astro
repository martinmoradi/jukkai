---
// Direction comp: the six-beat homepage blockout over the scroll-reactive
// mood field (spec: docs/design/homepage-score.md). Everything here is
// placeholder discipline: grey media boxes at intended aspect ratios, dummy
// type at real target sizes, copy borrowed from homepage-exploration.md as
// length-realistic filler. Nothing is frozen. Press D for the dev panel.
import { parseSceneLengthVh } from './mood-scroll-conductor';
import { createDefaultConfig } from './mood-scroll-config';
import styles from './MoodScroll.module.css';

// Sections render at their declared scene lengths before the conductor
// boots; the motion code re-applies the same data on every rebuild, so
// panel length edits reshape the page live.
const config = createDefaultConfig();
const sectionStyle = (key: string): string | undefined => {
  const scene = config.scenes.find((entry) => entry.key === key);
  if (!scene || scene.pin) return undefined;
  return `min-height: ${parseSceneLengthVh(scene.length)}vh`;
};

// Featured works for the galerie carousel: distinguishable placeholder
// tints so image-to-image transitions can be judged before real assets.
const featuredProjects = [
  { name: 'Projet 01 · [maison]', tint: '#8a4a33' },
  { name: 'Projet 02 · [appartement]', tint: '#96702f' },
  { name: 'Projet 03 · [restaurant]', tint: '#586647' },
  { name: 'Projet 04 · [bureaux]', tint: '#3d4c66' },
  { name: 'Projet 05 · [boutique]', tint: '#5d3f52' },
];

// Loose collage scatter for the dark room (positions are structure; the
// recede treatment is tunable). CSS vars so the static fallback can
// re-lay them out without fighting inline styles.
const collageItems = [
  { left: '5%', top: '10%', width: '17vw', aspect: '3 / 4' },
  { left: '76%', top: '7%', width: '19vw', aspect: '4 / 3' },
  { left: '9%', top: '60%', width: '15vw', aspect: '1 / 1' },
  { left: '72%', top: '56%', width: '18vw', aspect: '3 / 2' },
  { left: '43%', top: '4%', width: '13vw', aspect: '4 / 5' },
];

const collageItemStyle = (item: (typeof collageItems)[number]): string =>
  `--collage-left: ${item.left}; --collage-top: ${item.top}; ` +
  `--collage-width: ${item.width}; --collage-aspect: ${item.aspect};`;
---

<div class={styles.page} data-mood-root>
  <canvas class={styles.canvas} data-mood-canvas aria-hidden='true'></canvas>

  <main class={styles.main}>
    <section
      class={`${styles.section} ${styles.inkDark}`}
      style={sectionStyle('hero')}
      data-mood-section='hero'>
      <p class={styles.eyebrow}>Jukkai by Crystelle Terrasson</p>
      <h1 class={styles.display}>Des lieux dont on se souvient.</h1>
      <p class={styles.kicker}>
        Architecte d'intérieur à Rennes,
        <span class={styles.kickerSibling}>
          & un art shop, sous le même toit</span
        >
      </p>
      <a class={styles.cta} href='#'>Parlons de votre projet →</a>
      <p class={styles.meta}>
        ★ 4,9 · [XX] avis Google — UNAID · 30 ans de métier · 2 architectes ·
        depuis 2012
      </p>
    </section>

    <section
      class={`${styles.section} ${styles.inkDark}`}
      style={sectionStyle('umbrella')}
      data-mood-section='umbrella'>
      <p class={styles.statement}>
        Jukkai est un studio d'architecture d'intérieur et un art shop, sous le
        même toit, à Châteaugiron.
      </p>
      <p class={styles.meta}>
        Châteaugiron, à 20 minutes de Rennes · Depuis 2012
      </p>
    </section>

    <!-- Galerie takeover (experiment #57+#58): a sticky runway block. The
         backdrop is the dark room's own wall (hard section boundary while
         the composed room scrolls in), the sticky stage holds the beats:
         editorial, collage assembly, then the featured frame (a fixed
         overlay, below) grows to full bleed. Scroll drives geometry; the
         carousel drives content. -->
    <section
      class={`${styles.section} ${styles.inkLight} ${styles.galerie}`}
      data-mood-section='galerie'>
      <div
        class={styles.galerieBackdrop}
        data-galerie-backdrop
        aria-hidden='true'>
      </div>
      <div class={styles.galerieStage} data-galerie-stage>
        <div class={styles.galerieEditorial} data-galerie-editorial>
          <p class={styles.galerieDisplay}>Les projets</p>
          <p class={styles.galerieKicker}>
            Des lieux habités, pas des décors. [placeholder]
          </p>
        </div>
        <div class={styles.collage} data-galerie-collage aria-hidden='true'>
          {
            collageItems.map((item, index) => (
              <div
                class={`${styles.mediaBox} ${styles.collageItem}`}
                style={collageItemStyle(item)}
                data-collage-item
                data-label={`image projet · ${index + 1}`}
              />
            ))
          }
        </div>
        <!-- Static version (below 1024px / reduced motion), per
             gallery-mobile.png + gallery-tablet.png: the typographic beat,
             then the carousel with its chrome on the image. No collage. -->
        <div class={styles.staticFeatured} data-galerie-static>
          <div class={styles.staticStage} data-carousel-stage>
            {
              featuredProjects.map((project, index) => (
                <div
                  class={styles.slide}
                  style={`--slide-tint: ${project.tint}`}
                  data-carousel-slide
                  data-project-name={project.name}
                  data-label={project.name}
                  aria-hidden={index === 0 ? undefined : 'true'}
                />
              ))
            }
            <div class={styles.featuredChrome}>
              <p class={styles.featuredName} data-carousel-name>
                {featuredProjects[0].name}
              </p>
              <div class={styles.featuredNav}>
                <button
                  class={styles.navButton}
                  type='button'
                  data-carousel-prev
                  aria-label='Projet précédent'>←</button
                >
                <button
                  class={styles.navButton}
                  type='button'
                  data-carousel-next
                  aria-label='Projet suivant'>→</button
                >
              </div>
              <p class={styles.featuredCounter} data-carousel-counter>
                1/{featuredProjects.length}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hand-off seam (experiment #57): a sticky runway where the full-bleed
         featured image shrinks into an arch-masked door while the light
         chapter rises to the seam. The arch is the door; the sentence below
         invites you to push it. -->
    <section
      class={`${styles.section} ${styles.handoff}`}
      style={sectionStyle('handoff')}
      data-mood-section='handoff'>
      <div class={styles.handoffStage} data-handoff-stage>
        <div class={styles.handoffSlot} data-handoff-slot aria-hidden='true'>
          <div class={styles.slotStage} data-carousel-stage>
            {
              featuredProjects.map((project) => (
                <div
                  class={styles.slide}
                  style={`--slide-tint: ${project.tint}`}
                  data-carousel-slide
                  data-project-name={project.name}
                  data-label={project.name}
                />
              ))
            }
          </div>
        </div>
        <div
          class={`${styles.handoffPanel} ${styles.inkDark}`}
          data-handoff-panel>
          <div class={styles.handoffType} data-handoff-type>
            <p class={styles.handoffDisplay}>Venez pousser la porte.</p>
            <p class={styles.meta}>
              L'art shop ouvre en octobre 2026 · Châteaugiron [placeholder]
            </p>
          </div>
        </div>
      </div>
    </section>

    <section
      class={`${styles.section} ${styles.inkDark}`}
      style={sectionStyle('offerLadder')}
      data-mood-section='offerLadder'>
      <p class={styles.eyebrow}>Prestations</p>
      <p class={styles.statement}>
        Des missions à la mesure du projet, du conseil à la rénovation complète.
      </p>
      <ul class={styles.offerGrid}>
        <li class={styles.offerCard}>
          <p class={styles.offerName}>Conseil & mission déco</p>
          <p class={styles.offerLine}>
            [offre d'entrée — nom, prix et périmètre à valider]
          </p>
        </li>
        <li class={styles.offerCard}>
          <p class={styles.offerName}>Transformation ciblée</p>
          <p class={styles.offerLine}>
            Une pièce, une ambiance, un chantier maîtrisé. [fourchette]
          </p>
        </li>
        <li class={styles.offerCard}>
          <p class={styles.offerName}>Rénovation complète</p>
          <p class={styles.offerLine}>
            De la conception au suivi de chantier. 8-15% des travaux.
          </p>
        </li>
        <li class={styles.offerCard}>
          <p class={styles.offerName}>Espaces professionnels</p>
          <p class={styles.offerLine}>
            Bureaux, commerces, lieux qui reçoivent. [carte de renvoi]
          </p>
        </li>
      </ul>
      <a class={styles.cta} href='#'>Découvrir les prestations →</a>
    </section>

    <section
      class={`${styles.section} ${styles.inkDark}`}
      style={sectionStyle('artShop')}
      data-mood-section='artShop'>
      <p class={styles.eyebrow}>L'art shop ouvre en octobre 2026</p>
      <p class={styles.statement}>
        Une galerie vivante, pensée comme un art shop.
      </p>
      <div class={styles.printsRow}>
        <div
          class={`${styles.mediaBox} ${styles.printBox}`}
          data-label='œuvre · 3:4'>
        </div>
        <div
          class={`${styles.mediaBox} ${styles.printBox}`}
          data-label='œuvre · 3:4'>
        </div>
        <div
          class={`${styles.mediaBox} ${styles.printBox}`}
          data-label='œuvre · 3:4'>
        </div>
      </div>
      <a class={styles.cta} href='#'>Venez pousser la porte →</a>
    </section>

    <section
      class={`${styles.section} ${styles.inkDark}`}
      style={sectionStyle('trust')}
      data-mood-section='trust'>
      <p class={styles.trustLine}>
        Deux architectes d'intérieur, un art shop, une même exigence.
      </p>
      <p class={styles.meta}>
        2 architectes · 30 ans de métier · depuis 2012 · UNAID
      </p>
      <p class={styles.meta}>★ 4,9 · [XX] avis Google</p>
      <a class={styles.cta} href='#'>Découvrir l'atelier →</a>
    </section>

    <section
      class={`${styles.section} ${styles.inkLight} ${styles.finale}`}
      style={sectionStyle('finale')}
      data-mood-section='finale'>
      <p class={styles.finaleLine} data-mood-parallax='0.22'>Des lieux</p>
      <p class={styles.finaleLine} data-mood-parallax='0.08'>dont on</p>
      <p class={styles.finaleLine} data-mood-parallax='-0.1'>se souvient.</p>
      <a class={`${styles.cta} ${styles.finaleCta}`} href='#'>
        Parlons de votre projet →
      </a>
      <div class={styles.footerBand}>
        Jukkai — Châteaugiron · comp /directions/mood-scroll · D&nbsp;: réglages
      </div>
    </section>
  </main>

  <!-- Featured overlay: one fixed frame both takeover timelines animate.
       It appears mid-galerie, grows to full bleed, hides the section seam
       during the unpin traversal, then morphs into the arch and swaps into
       the hand-off's inline slot. Wheel events pass through; only the
       carousel buttons take the pointer. -->
  <div class={styles.featuredOverlay} data-galerie-overlay>
    <div
      class={`${styles.featuredFrame} ${styles.inkLight}`}
      data-galerie-frame>
      <div class={styles.frameStage} data-carousel-stage>
        {
          featuredProjects.map((project) => (
            <div
              class={styles.slide}
              style={`--slide-tint: ${project.tint}`}
              data-carousel-slide
              data-project-name={project.name}
              data-label={project.name}
            />
          ))
        }
      </div>
      <div class={styles.featuredChrome} data-galerie-chrome>
        <p class={styles.featuredName} data-carousel-name aria-live='polite'>
          {featuredProjects[0].name}
        </p>
        <div class={styles.featuredNav}>
          <button
            class={styles.navButton}
            type='button'
            data-carousel-prev
            aria-label='Projet précédent'>←</button
          >
          <button
            class={styles.navButton}
            type='button'
            data-carousel-next
            aria-label='Projet suivant'>→</button
          >
        </div>
        <p class={styles.featuredCounter} data-carousel-counter>
          1/{featuredProjects.length}
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  import { createDefaultConfig } from './mood-scroll-config';
  import { initMoodScroll } from './mood-scroll-motion';
  import { createTunableRegistry } from './mood-scroll-tunables';
  import styles from './MoodScroll.module.css';

  const root = document.querySelector('[data-mood-root]');
  if (root instanceof HTMLElement) {
    const config = createDefaultConfig();
    const tunables = createTunableRegistry(config);
    const moodScroll = initMoodScroll(root, config, tunables);
    if (import.meta.env.DEV) {
      void import('./mood-scroll-panel').then(({ initMoodPanel }) => {
        initMoodPanel(
          config,
          tunables,
          {
            panel: styles.panel,
            hidden: styles.panelHidden,
            title: styles.panelTitle,
            dragHandle: styles.panelDragHandle,
            presetButton: styles.panelPresetButton,
            titleActions: styles.panelTitleActions,
            titleAction: styles.panelTitleAction,
            rename: styles.panelRename,
            renameStamp: styles.panelRenameStamp,
            renameInput: styles.panelRenameInput,
            jumpRow: styles.panelJumpRow,
            jumpScene: styles.panelJumpScene,
            jumpButton: styles.panelJumpButton,
            jumpStopButton: styles.panelJumpStopButton,
            group: styles.panelGroup,
            groupHeader: styles.panelGroupHeader,
            groupTitle: styles.panelGroupTitle,
            groupMeta: styles.panelGroupMeta,
            groupToggle: styles.panelGroupToggle,
            groupBody: styles.panelGroupBody,
            subheading: styles.panelSubheading,
            row: styles.panelRow,
            value: styles.panelValue,
            colorInput: styles.panelColorInput,
            presetList: styles.panelPresetList,
            presetListItem: styles.panelPresetListItem,
            status: styles.panelStatus,
          },
          moodScroll?.devTools,
        );
      });
    }
  }
</script>
