---
import type { MarketingPage } from '../../lib/pages';
import HomeArtShopInvitation from './HomeArtShopInvitation.astro';
import HomeClosingCta from './HomeClosingCta.astro';
import HomeHeader from './HomeHeader.astro';
import HomeHero from './HomeHero.astro';
import HomeOfferLadderTeaser from './HomeOfferLadderTeaser.astro';
import styles from './HomePage.module.css';
import HomeProjectsTeaser from './HomeProjectsTeaser.astro';
import HomeTrustStrip from './HomeTrustStrip.astro';
import HomeUmbrellaAnswer from './HomeUmbrellaAnswer.astro';

interface Props {
  page: MarketingPage;
}

const { page } = Astro.props;
---

<div class={styles.page}>
  <HomeHeader />
  <main class={styles.main}>
    <HomeHero page={page} />
    <HomeUmbrellaAnswer />
    <HomeProjectsTeaser />
    <HomeOfferLadderTeaser />
    <HomeArtShopInvitation />
    <HomeTrustStrip />
    <HomeClosingCta primaryCta={page.primaryCta} />
  </main>
</div>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }

  body {
    margin: 0;
  }
</style>
