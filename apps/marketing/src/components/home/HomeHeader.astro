---
import Wordmark from '../Wordmark.astro';
import { getHomePrimaryNavigationPages } from './home-content';
import styles from './HomeHeader.module.css';

const navigationPages = getHomePrimaryNavigationPages();
---

<header class={styles.header}>
  <a class={styles.lockup} href='/'>
    <Wordmark class={styles.wordmark} />
    <span class={styles.lockupLine}>by Crystelle Terrasson</span>
  </a>
  <nav class={styles.nav} aria-label='Navigation principale'>
    {
      navigationPages.map((item) => (
        <a class={styles.navLink} href={item.slug}>
          {item.navLabel}
        </a>
      ))
    }
  </nav>
</header>
