---
import styles from './HomeSections.module.css';
---

<section
  class={`${styles.section} ${styles.umbrella}`}
  data-home-section='umbrella-answer'>
  <div class={styles.sectionHeader}>
    <p class={styles.kicker}>La réponse</p>
    <h2 class={styles.sectionTitle}>
      Architecture intérieure, art shop et regard matière, au même endroit.
    </h2>
  </div>
  <div class={styles.textStack}>
    <p>
      Jukkai rassemble le travail d’architecture intérieure de Crystelle
      Terrasson et un lieu ouvert autour des œuvres, des matériaux et des
      rencontres.
    </p>
    <p>
      Le studio accompagne les projets d’habitat et de lieux professionnels avec
      une attention concrète aux usages, au budget, au chantier et à la
      personnalité du lieu.
    </p>
  </div>
</section>
