---
import { HOME_PROJECT_PLACEHOLDERS } from './home-content';
import styles from './HomeSections.module.css';
---

<section
  class={`${styles.section} ${styles.projects}`}
  data-home-section='projects-teaser'>
  <div class={styles.sectionHeader}>
    <p class={styles.kicker}>Projets</p>
    <h2 class={styles.sectionTitle}>Une première sélection à publier.</h2>
    <a class={styles.textLink} href='/projets/'>Voir les projets</a>
  </div>
  <div class={styles.cardGrid}>
    {
      HOME_PROJECT_PLACEHOLDERS.map((project) => (
        <article class={styles.projectCard}>
          <div class={styles.placeholderFrame} aria-hidden='true'>
            <span>Visuel à valider</span>
          </div>
          <p class={styles.validationLabel}>{project.label}</p>
          <h3 class={styles.cardTitle}>{project.title}</h3>
          <p class={styles.cardCopy}>{project.meta}</p>
        </article>
      ))
    }
  </div>
</section>
