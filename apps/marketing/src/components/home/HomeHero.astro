---
import type { MarketingPage } from '../../lib/pages';
import Wordmark from '../Wordmark.astro';
import { HOME_PROOF_CLAIMS } from './home-content';
import {
  HOME_HERO_DISPLAY_EMPHASIS,
  HOME_HERO_DISPLAY_ROWS,
  HOME_HERO_DISPLAY_TEXT,
  HOME_HERO_FIELD_IMAGE,
  HOME_HERO_PRINTS,
} from './home-hero';
import heroStyles from './HomeHero.module.css';
import sectionStyles from './HomeSections.module.css';

interface Props {
  page: MarketingPage;
}

const { page } = Astro.props;

const displayRowStyles = [
  heroStyles.displayRowFirst,
  heroStyles.displayRowSecond,
  heroStyles.displayRowThird,
] as const;

// Split the emphasized tail out of its row so the italic flourish is markup,
// not a second copy of the sentence.
const displayRows = HOME_HERO_DISPLAY_ROWS.map((text, index) => {
  const hasEmphasis = text.endsWith(HOME_HERO_DISPLAY_EMPHASIS);
  return {
    className: displayRowStyles[index],
    lead: hasEmphasis
      ? text.slice(0, text.length - HOME_HERO_DISPLAY_EMPHASIS.length)
      : text,
    emphasis: hasEmphasis ? HOME_HERO_DISPLAY_EMPHASIS : null,
  };
});
---

<section
  class={`${sectionStyles.section} ${heroStyles.hero}`}
  data-home-section='hero'
  aria-labelledby='home-title'>
  <img
    class={heroStyles.fieldImage}
    src={HOME_HERO_FIELD_IMAGE}
    alt=''
    aria-hidden='true'
    decoding='async'
    fetchpriority='high'
  />

  <div class={heroStyles.constellation} aria-hidden='true'>
    {
      HOME_HERO_PRINTS.map((print) => (
        <figure
          class:list={[
            heroStyles.print,
            print.layer === 'near' ? heroStyles.printNear : heroStyles.printFar,
            print.mobileWidthVw ? heroStyles.printMobile : null,
          ]}
          style={`--print-x:${print.xPercent}%; --print-y:${print.yPercent}%; --print-w:${print.widthVw}vw;${print.mobileWidthVw ? ` --print-mobile-w:${print.mobileWidthVw}vw;` : ''}`}>
          <img src={print.imageSrc} alt='' loading='eager' decoding='async' />
        </figure>
      ))
    }
  </div>

  <div class={heroStyles.cluster}>
    <h1 id='home-title' class={heroStyles.h1}>{page.h1}</h1>
    <p class={heroStyles.display} aria-label={HOME_HERO_DISPLAY_TEXT}>
      {
        displayRows.map((row) => (
          <span
            class:list={[heroStyles.displayRow, row.className]}
            aria-hidden='true'>
            {row.lead}
            {row.emphasis ? (
              <em class={heroStyles.displayEmphasis}>{row.emphasis}</em>
            ) : null}
          </span>
        ))
      }
    </p>
    <div class={heroStyles.lockup} aria-label='Jukkai by Crystelle Terrasson'>
      <Wordmark class={heroStyles.wordmark} />
      <p class={heroStyles.byline}>by Crystelle Terrasson</p>
    </div>
    {
      page.primaryCta ? (
        <a class={heroStyles.cta} href={page.primaryCta.href}>
          {page.primaryCta.label}
          <span class={heroStyles.ctaArrow} aria-hidden='true'>
            &rarr;
          </span>
        </a>
      ) : null
    }
  </div>

  <p class={heroStyles.proof}>{HOME_PROOF_CLAIMS.join(' · ')}</p>
</section>
