---
import { HOME_ART_PLACEHOLDERS } from './home-content';
import styles from './HomeSections.module.css';
---

<section
  class={`${styles.section} ${styles.artShop}`}
  data-home-section='art-shop-invitation'>
  <div class={styles.artPanel} aria-hidden='true'>
    <span>Œuvres à photographier</span>
  </div>
  <div class={styles.artCopy}>
    <p class={styles.kicker}>L’art shop</p>
    <h2 class={styles.sectionTitle}>Un lieu pour rencontrer les œuvres.</h2>
    <p>
      La sélection reste à documenter avant publication. Cette invitation garde
      la place de l’art shop sans transformer des pistes en preuves.
    </p>
    <ul class={styles.inlineList}>
      {
        HOME_ART_PLACEHOLDERS.map((item) => (
          <li>
            <span>{item.label}</span>
            {item.text}
          </li>
        ))
      }
    </ul>
    <a class={styles.secondaryCta} href='/art-shop/'>Découvrir l’art shop</a>
  </div>
</section>
