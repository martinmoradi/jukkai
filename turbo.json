{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".prettierignore",
    ".prettierrc.json",
    "bun.lock",
    "commitlint.config.mjs",
    "eslint.config.mjs",
    "package.json",
    "stylelint.config.mjs",
    "turbo.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {},
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
