{
  "name": "jukkai",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@astrojs/language-server": "2.16.11"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "dev": "turbo run dev",
    "dev:marketing": "bun run --cwd apps/marketing dev",
    "fonts:check": "bun scripts/fonts-generated-check.ts",
    "fonts:fixture": "bun scripts/fonts-fixture.ts",
    "fonts:prefetch": "bun scripts/fonts-prefetch.ts",
    "format": "prettier --write --ignore-unknown README.md package.json tsconfig.json tsconfig.scripts.json turbo.json eslint.config.mjs stylelint.config.mjs commitlint.config.mjs \".github/**/*\" \"apps/**/*\" \"docs/operations/fonts.md\" \"scripts/**/*\" \".env.example\"",
    "format:check": "prettier --check --ignore-unknown README.md package.json tsconfig.json tsconfig.scripts.json turbo.json eslint.config.mjs stylelint.config.mjs commitlint.config.mjs \".github/**/*\" \"apps/**/*\" \"docs/operations/fonts.md\" \"scripts/**/*\" \".env.example\"",
    "lint": "eslint scripts --ext .ts && turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "prepare": "husky",
    "test": "bun test ./scripts && turbo run test",
    "typecheck": "tsc --noEmit -p tsconfig.json && turbo run typecheck"
  },
  "lint-staged": {
    "*.{astro,ts,js,mjs,cjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,jsonc,md,mdx,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/bun": "1.3.14",
    "@vitest/eslint-plugin": "^1.6.23",
    "astro-eslint-parser": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.14.1",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
